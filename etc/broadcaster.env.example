# Icecast
ICECAST_URL="icecast://source:PASSWORD@live.blklst.fi:8000/blklistlive.mp3"
PUBLIC_STREAM_URL="http://live.blklst.fi:8000/blklistlive.mp3"

# Discord
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/...."

# ALSA capture
ALSA_DEVICE="plughw:CARD=T6,DEV=0"
RATE="48000"
IN_CH="2"
BITRATE="256k"
GAIN_DB="6dB"
EXTRA_PARAMS=""
OUTPUT_CODEC="pcm_s16le"
OUTPUT_CONTENT_TYPE="audio/wav"
OUTPUT_FORMAT="wav"

# Cloudflare
CF_API_TOKEN="***"
CF_ZONE_ID="***"
CF_RECORD_ID="***"
CF_RECORD_NAME="live.blklst.fi"
CF_TTL="120"
CF_PROXIED="false"